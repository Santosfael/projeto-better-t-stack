{
  "name": "api-proffy",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "check-types": "npm run check-types --workspaces",
    "dev:server": "npm run dev --workspace server",
    "db:push": "npm run db:push --workspace @api-proffy/db",
    "db:studio": "npm run db:studio --workspace @api-proffy/db",
    "db:generate": "npm run db:generate --workspace @api-proffy/db",
    "db:migrate": "npm run db:migrate --workspace @api-proffy/db",
    "db:start": "npm run db:start --workspace @api-proffy/db",
    "db:watch": "npm run db:watch --workspace @api-proffy/db",
    "db:stop": "npm run db:stop --workspace @api-proffy/db",
    "db:down": "npm run db:down --workspace @api-proffy/db",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@api-proffy/env": "*",
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@api-proffy/config": "*",
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^22.13.14",
    "typescript": "^5"
  },
  "packageManager": "npm@10.9.3"
}
